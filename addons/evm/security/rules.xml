<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="evm_case_rule_kine_own" model="ir.rule">
        <field name="name">EVM case - kine owns record</field>
        <field name="model_id" ref="model_evm_case"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_kine'))]"/>
        <field name="domain_force">[('kine_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="evm_case_rule_patient_own" model="ir.rule">
        <field name="name">EVM case - patient owns record</field>
        <field name="model_id" ref="model_evm_case"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_patient'))]"/>
        <field name="domain_force">[('patient_user_id', '=', user.id), ('state', 'in', ('pending', 'accepted', 'closed'))]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="evm_case_rule_fondation_all" model="ir.rule">
        <field name="name">EVM case - fondation full access</field>
        <field name="model_id" ref="model_evm_case"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_fondation'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="evm_case_rule_admin_all" model="ir.rule">
        <field name="name">EVM case - admin full access</field>
        <field name="model_id" ref="model_evm_case"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="evm_payment_request_rule_kine_own" model="ir.rule">
        <field name="name">EVM payment request - kine owns related case</field>
        <field name="model_id" ref="model_evm_payment_request"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_kine'))]"/>
        <field name="domain_force">[('case_id.kine_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="evm_payment_request_rule_patient_own" model="ir.rule">
        <field name="name">EVM payment request - patient owns record</field>
        <field name="model_id" ref="model_evm_payment_request"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_patient'))]"/>
        <field name="domain_force">[('patient_user_id', '=', user.id), ('case_id.state', 'in', ('accepted', 'closed'))]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="evm_payment_request_rule_fondation_all" model="ir.rule">
        <field name="name">EVM payment request - fondation full access</field>
        <field name="model_id" ref="model_evm_payment_request"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_fondation'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="evm_payment_request_rule_admin_all" model="ir.rule">
        <field name="name">EVM payment request - admin full access</field>
        <field name="model_id" ref="model_evm_payment_request"/>
        <field name="groups" eval="[(4, ref('evm.group_evm_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
